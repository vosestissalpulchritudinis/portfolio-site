<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Home</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>

<nav>
<a href="/">Home</a>
<a href="/works">Works</a>
<a href="/about">About</a>
<a href="/contact">Contact</a>
<a href="/en">EN</a>
</nav>

<h1>Portfolio</h1>

<p><%= concept %></p>

<section>
  <h2>Recent Works</h2>

  <div class="grid">
    <% if (works && works.length) { %>
      <% works.forEach(work => { %>
        <a href="/works/<%= work.id %>" class="card">
          <div>
            <% if (work.image) { %>
              <img src="/uploads/<%= work.image %>" style="max-width:100%">
            <% } %>
            <h3><%= work.title %></h3>
            <p><%= work.category %> / <%= work.year %></p>
          </div>
        </a>
      <% }) %>
    <% } else { %>
      <p>No works.</p>
    <% } %>
  </div>
</section>

</body>
</html>