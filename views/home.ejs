<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Home</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>

<nav>
<a href="/">Home</a>
<a href="/works">Works</a>
<a href="/about">About</a>
<a href="/contact">Contact</a>
</nav>

<section>

<h1>ICHINO TAICHI</h1>

<p style="max-width:700px; font-size:20px;">
<%= concept %>
</p>

</section>

<section style="margin-top:80px;">

<h2>Recent Works</h2>

<% works.forEach(work => { %>

<div>

<% if(work.image){ %>
<img src="/uploads/<%= work.image %>">
<% } %>

<h2>
<a href="/works/<%= work.id %>">
<%= work.title %>
</a>
</h2>

<p><%= work.category %> / <%= work.year %></p>

</div>

<% }) %>

</section>

<section style="margin-top:60px; margin-bottom:100px;">

<p>
<a href="/works">View Archive →</a>
</p>

<p>
<a href="/about">Read Statement →</a>
</p>

</section>

</body>
</html>