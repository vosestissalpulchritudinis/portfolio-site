<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Works</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>

<nav>
<a href="/">Home</a>
<a href="/works">Works</a>
<a href="/about">About</a>
<a href="/contact">Contact</a>
</nav>

<h1>Works</h1>

<p class="index-note">
Archive index / reading interface
</p>

<div class="reader">

<% works.forEach(work => { %>

<a class="entry" href="/works/<%= work.id %>">

  <div class="meta">
    <span class="title"><%= work.title %></span>
    <span class="category"><%= work.category %></span>
    <span class="year"><%= work.year %></span>
  </div>

  <% if(work.image){ %>
    <img src="/uploads/<%= work.image %>">
  <% } %>

</a>

<% }) %>

</div>

</body>
</html>