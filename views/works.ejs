<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Works</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>

<nav>
<a href="/">Home</a>
<a href="/works">Works</a>
<a href="/about">About</a>
<a href="/contact">Contact</a>
</nav>

<h1>Works</h1>

<div class="grid">
  <% works.forEach(work => { %>
    <a href="/works/<%= work.id %>" class="card">
      <% if (work.image) { %>
        <img src="/uploads/<%= work.image %>">
      <% } %>
      <h3><%= work.title %></h3>
      <p><%= work.category %> / <%= work.year %></p>
    </a>
  <% }) %>
</div>

</body>
</html>