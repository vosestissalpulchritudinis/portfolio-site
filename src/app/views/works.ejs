<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>Works</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>

<nav>
<a href="/">Home</a>
<a href="/works">Works</a>
<a href="/about">About</a>
<a href="/contact">Contact</a>
</nav>

<h1>Works</h1>

<% works.forEach(work => { %>
<div>
  <h2>
    <a href="/works/<%= work.id %>">
      <%= work.title %>
    </a>
  </h2>
  <p><%= work.category %> / <%= work.year %></p>
</div>
<% }) %>

</body>
</html>